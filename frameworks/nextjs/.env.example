# Copy this file to .env.local and fill in your values.
# .env.local is gitignored; .env.example is committed as a template.

# Postgres connection string used by this example.
# Point this at your existing Postgres, or use the docker-compose.yml
# in this directory (which boots Postgres with user=gl, password=gl, db=todos).
DATABASE_URL=postgresql://gl:gl@localhost:5432/todos
